# Pick one export mode before deployment. This file uses Logfire SDK mode.
LOGFIRE_TOKEN=replace-with-write-token
LOGFIRE_SEND_TO_LOGFIRE=if-token-present
LOGFIRE_SERVICE_NAME=replace-with-system-probe
LOGFIRE_ENVIRONMENT=replace-with-environment
SERVICE_NAMESPACE=replace-with-org-or-system
SERVICE_INSTANCE_ID=replace-with-probe-host-or-worker-id
MONITOR_ID=replace-with-system/replace-with-subject/replace-with-check
SUBJECT_ID=replace-with-thing-being-checked
# Generate OTEL_RESOURCE_ATTRIBUTES from the identity values above in the probe
# startup path; do not maintain a second hand-edited identity source here.
# Generic OTLP mode uses OTEL_EXPORTER_OTLP_ENDPOINT and
# OTEL_EXPORTER_OTLP_HEADERS instead; do not mix it into this SDK env file.
